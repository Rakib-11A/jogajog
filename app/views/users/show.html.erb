<h1><%= @user.name %>'s Profile</h1>

<p>Email: <%= @user.email %></p>

<% if @user == current_user %>
  <p>This is your own profile.</p>
<% else %>
  <% if current_user.friends.include?(@user) %>
    <p>You are friends with <%= @user.name %>.</p>
  <% elsif current_user.friend_requests_sent.where(receiver: @user).exists? %>
    <p>Friend request sent to <%= @user.name %>.</p>
  <% elsif current_user.friend_requests_received.where(sender: @user).exists? %>
    <p><%= @user.name %> sent you a friend request.</p>
    <%= button_to "Accept", friendships_path(friend_id: @user.id), method: :post %>
  <% else %>
    <%= button_to "Send Friend Request", friend_requests_path(receiver_id: @user.id), method: :post %>
  <% end %>
<% end %>
