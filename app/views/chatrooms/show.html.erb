<div class="bg-white rounded-lg shadow-md p-4">
  <h2 class="text-xl font-bold mb-4"><%= @chatroom.name %></h2>

  <div id="messages" class="h-96 overflow-y-scroll bg-gray-50 p-3 rounded border mb-4">
    <%= render @messages.compact %>
  </div>

  <%= form_with model: [@chatroom, Message.new], data: { turbo_frame: "_top" }, class: "flex gap-2" do |f| %>
    <%= f.text_field :content, class: "flex-1 rounded border-gray-300 focus:ring-primary", placeholder: "মেসেজ লিখুন..." %>
    <%= f.submit "পাঠান", class: "bg-blue-700 text-white px-4 py-2 rounded hover:bg-secondary" %>
  <% end %>
</div>
